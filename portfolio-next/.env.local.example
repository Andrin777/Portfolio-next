# ─────────────────────────────────────────────────────────────────────────
# Sanity — copy this file to ".env.local" and fill in your own values.
# Create a project for free at https://www.sanity.io/manage
# ─────────────────────────────────────────────────────────────────────────

# Found in your project settings on sanity.io/manage (or run `npx sanity init`)
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# API version — keep as a date; only bump it deliberately.
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Write token — ONLY needed for the one-time content import (`npm run import`).
# Create one under: sanity.io/manage → API → Tokens → "Editor" permission.
# Never commit this. It is read server-side / by the script only.
SANITY_API_WRITE_TOKEN="your_write_token"
